<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_serein">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="760dp"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_panel"
            android:orientation="vertical">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_user_plus" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Create Account"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Join the Serein Stay family!"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="italic" />

            <EditText
                android:id="@+id/edit_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:background="@drawable/bg_input"
                android:hint="Full Name"
                android:minHeight="52dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:minHeight="52dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Password"
                android:inputType="textPassword"
                android:minHeight="52dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Phone Number"
                android:inputType="phone"
                android:minHeight="52dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_national_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="National ID"
                android:minHeight="52dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_birth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Select Date of Birth"
                android:minHeight="52dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <Button
                android:id="@+id/button_create_account"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_button_primary"
                android:text="Sign Up"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_back_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:text="Back to Log In"
                android:textAllCaps="false"
                android:textColor="@color/primary_dark" />

            <TextView
                android:id="@+id/text_guest_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Continue as guest"
                android:textColor="@color/primary_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_status"
                android:textColor="@color/muted" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>

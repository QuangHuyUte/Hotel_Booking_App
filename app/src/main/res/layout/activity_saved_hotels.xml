<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_booking_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_booking_page"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="22dp"
        android:paddingEnd="16dp"
        android:paddingBottom="90dp">

        <Button
            android:id="@+id/button_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_back_circle"
            android:drawableTop="@drawable/ic_back_chevron"
            android:elevation="3dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text=""
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Đã lưu"
            android:textColor="@color/booking_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_status"
            android:padding="10dp"
            android:textColor="@color/booking_blue"
            android:textSize="13sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_wishlist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/button_back_bottom"
            android:layout_width="116dp"
            android:layout_height="44dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_booking_secondary"
            android:text="Quay lại"
            android:textAllCaps="false"
            android:textColor="@color/booking_blue"
            android:textStyle="bold" />
    </LinearLayout>

    <include layout="@layout/view_bottom_nav_cabins" />
</FrameLayout>

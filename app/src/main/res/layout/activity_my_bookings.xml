<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_booking_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_booking_page"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="22dp"
        android:paddingEnd="16dp"
        android:paddingBottom="90dp">

        <Button
            android:id="@+id/button_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_back_circle"
            android:drawableTop="@drawable/ic_back_chevron"
            android:elevation="3dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text=""
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trips"
            android:textColor="@color/booking_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Review confirmations, pending bookings, payments, and past stays."
            android:textColor="@color/booking_muted"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_search_panel"
            android:orientation="vertical">

            <EditText
                android:id="@+id/edit_search_bookings"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_booking_field"
                android:hint="Search cabin, date, status"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/booking_text"
                android:textColorHint="@color/booking_muted"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spinner_filter"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_booking_field"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_status"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:textColor="@color/booking_blue"
            android:textSize="13sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_bookings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/button_back_bottom"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_booking_secondary"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/booking_blue"
            android:textStyle="bold" />
    </LinearLayout>

    <include layout="@layout/view_bottom_nav_cabins" />
</FrameLayout>

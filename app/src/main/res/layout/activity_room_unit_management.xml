<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_serein"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <Button
            android:id="@+id/button_back"
            android:layout_width="96dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Quay lại"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_room_unit_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Quản lý phòng"
            android:textColor="@color/primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_room_unit_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_manager_panel"
            android:padding="14dp"
            android:textColor="@color/ink"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edit_range_start"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="Từ ngày"
                android:inputType="date"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_range_end"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="Đến ngày"
                android:inputType="date"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />
        </LinearLayout>

        <Button
            android:id="@+id/button_refresh_units"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Xem phòng trống theo lịch"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/container_room_units"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/text_selected_calendar_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_manager_panel"
            android:padding="14dp"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/container_room_calendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/section_block_selected_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_manager_panel"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_block_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chặn lịch phòng đang chọn"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edit_block_start"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="Từ ngày"
                    android:inputType="date"
                    android:singleLine="true"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted" />

                <EditText
                    android:id="@+id/edit_block_end"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="Đến ngày"
                    android:inputType="date"
                    android:singleLine="true"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted" />
            </LinearLayout>

            <EditText
                android:id="@+id/edit_block_reason"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Lý do: walk-in, OTA, bảo trì..."
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <Button
                android:id="@+id/button_block_selected_room"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Chặn lịch phòng này"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_status"
            android:padding="10dp"
            android:textColor="@color/muted" />
    </LinearLayout>
</ScrollView>

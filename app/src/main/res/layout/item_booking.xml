<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_booking_card"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="142dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/image_booking_cabin"
        android:layout_width="112dp"
        android:layout_height="142dp"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_background" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_booking_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/booking_blue"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_booking_status"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="@drawable/bg_booking_badge_green"
                android:gravity="center"
                android:paddingStart="9dp"
                android:paddingEnd="9dp"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_booking_nights"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:textColor="@color/booking_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_booking_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="@color/booking_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/text_booking_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="@color/booking_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/text_booking_created"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/booking_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/button_booking_action"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_booking_secondary"
            android:textAllCaps="false"
            android:textColor="@color/booking_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>

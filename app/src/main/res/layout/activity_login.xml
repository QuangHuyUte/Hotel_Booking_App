<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/booking_blue">

    <com.example.hotel_booking_app.ui.views.AnimatedVietnamBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.72" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="760dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="88dp"
            android:paddingEnd="20dp"
            android:paddingBottom="34dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_auth_panel_strong"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="118dp"
                    android:layout_height="132dp"
                    android:layout_gravity="center_horizontal"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:src="@drawable/vietnam_red_logo" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Đăng nhập để quản lý chuyến đi, chỗ đã lưu và thanh toán."
                    android:textColor="#DDEBFF"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edit_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_input"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:minHeight="52dp"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted" />

                <EditText
                    android:id="@+id/edit_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:minHeight="52dp"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted" />

                <Button
                    android:id="@+id/button_login"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Đăng nhập"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/button_gmail_login"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_google_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Đăng nhập bằng Gmail"
                    android:textColor="@color/booking_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_status"
                    android:padding="12dp"
                    android:textColor="@color/muted"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/text_forgot_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="Quên mật khẩu?"
                    android:textColor="@color/primary_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_signup_link"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Tạo tài khoản"
                    android:textColor="@color/ink"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_guest_link"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Tiếp tục với vai trò khách"
                    android:textColor="@color/primary_dark"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/button_close"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="34dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_auth_close"
        android:clickable="true"
        android:elevation="20dp"
        android:focusable="true"
        android:gravity="center"
        android:text="X"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />
</FrameLayout>

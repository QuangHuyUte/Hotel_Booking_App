<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_serein"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="760dp"
        android:orientation="vertical"
        android:padding="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_panel"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_form_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Thêm khách sạn mới"
                android:textColor="@color/primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Tên khách sạn"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_cabin_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Tên"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Vị trí"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_location"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Vị trí"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Sức chứa tối đa"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_capacity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Sức chứa tối đa"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Giá tiêu chuẩn"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_price"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Giá"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Giảm giá"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_discount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Giảm giá"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Mô tả"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_description"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Mô tả"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Tiện nghi"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/container_amenities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Ảnh khách sạn"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_pick_image"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_button_primary"
                android:text="Chọn ảnh"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_image"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="URL ảnh hoặc ảnh đã chọn"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Loại phòng"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/container_room_types"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <Spinner
                android:id="@+id/spinner_room_category"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input" />

            <EditText
                android:id="@+id/edit_room_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Tên phòng"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edit_room_total"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="Số phòng"
                    android:inputType="number"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted" />

                <EditText
                    android:id="@+id/edit_room_guests"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                android:hint="Người lớn"
                    android:inputType="number"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edit_room_size"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="m2"
                    android:inputType="number"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted" />

                <Spinner
                    android:id="@+id/spinner_bed_type"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input" />
            </LinearLayout>

            <EditText
                android:id="@+id/edit_room_bed_count"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Giường"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_room_price"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Giá phòng cơ bản"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <Button
                android:id="@+id/button_save_room_type"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Lưu loại phòng"
                android:textAllCaps="false"
                android:textColor="@color/primary_dark"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_save_cabin"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_primary"
                android:text="Tạo khách sạn"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_status"
                android:padding="10dp"
                android:textColor="@color/muted" />
        </LinearLayout>

        <Button
            android:id="@+id/button_back_bottom"
            android:layout_width="116dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Quay lại"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_booking_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="22dp"
            android:paddingEnd="16dp"
            android:paddingBottom="100dp">

            <Button
                android:id="@+id/button_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_back_circle"
                android:drawableTop="@drawable/ic_back_chevron"
                android:elevation="3dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text=""
                android:textAllCaps="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tin nhắn"
                android:textColor="@color/booking_text"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_status"
                android:padding="10dp"
                android:textColor="@color/booking_blue"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/container_conversations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical" />

            <Button
                android:id="@+id/button_back_bottom"
                android:layout_width="116dp"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_booking_secondary"
                android:text="Quay lại"
                android:textAllCaps="false"
                android:textColor="@color/booking_blue"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/view_bottom_nav_cabins" />

    <include
        layout="@layout/view_bottom_nav_manager"
        android:visibility="gone" />
</FrameLayout>

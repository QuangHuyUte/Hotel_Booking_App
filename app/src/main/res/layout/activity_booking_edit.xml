<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_serein"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="30dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <Button
            android:id="@+id/button_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_back_circle"
            android:drawableTop="@drawable/ic_back_chevron"
            android:elevation="4dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text=""
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Sửa đặt phòng"
                android:textColor="@color/primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="Số khách"
                android:textColor="@color/ink"
                android:textSize="17sp" />

            <EditText
                android:id="@+id/edit_guests"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Số khách: 1"
                android:inputType="number"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/primary"
                android:textColorHint="@color/primary"
                android:textSize="20sp" />

            <CheckBox
                android:id="@+id/check_breakfast"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:buttonTint="@color/primary"
                android:text="Thêm bữa sáng"
                android:textColor="@color/ink"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Yêu cầu đặc biệt"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Cho chúng tôi biết các yêu cầu đặc biệt cho kỳ nghỉ của bạn"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edit_observations"
                android:layout_width="match_parent"
                android:layout_height="118dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Nhập yêu cầu đặc biệt tại đây..."
                android:padding="16dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Ví dụ: nhận phòng sớm, trả phòng muộn, ăn kiêng, chuẩn bị dịp kỷ niệm..."
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <Button
                android:id="@+id/button_update_booking"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_button_primary"
                android:text="Cập nhật đặt phòng"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_status"
                android:padding="10dp"
                android:textColor="@color/muted"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/button_back_bottom"
            android:layout_width="116dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Quay lại"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>

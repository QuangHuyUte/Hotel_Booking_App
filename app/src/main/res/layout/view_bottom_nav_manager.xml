<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nav_manager_root"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:layout_gravity="bottom"
    android:background="@drawable/bg_manager_nav"
    android:elevation="12dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <LinearLayout
        android:id="@+id/nav_manager_dashboard"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/icon_manager_dashboard"
            android:layout_width="34dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_manager_icon_active"
            android:contentDescription="Quản lý"
            android:padding="6dp"
            android:src="@drawable/ic_nav_home"
            android:tint="@color/booking_blue" />

        <TextView
            android:id="@+id/text_manager_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Quản lý"
            android:textColor="@color/booking_blue"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_manager_messages"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/icon_manager_messages"
            android:layout_width="34dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_manager_icon_idle"
            android:contentDescription="Tin nhắn"
            android:padding="6dp"
            android:src="@drawable/ic_nav_messages"
            android:tint="@color/booking_muted" />

        <TextView
            android:id="@+id/text_manager_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Tin nhắn"
            android:textColor="@color/booking_muted"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_manager_transactions"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/icon_manager_transactions"
            android:layout_width="34dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_manager_icon_idle"
            android:contentDescription="Giao dịch"
            android:padding="6dp"
            android:src="@drawable/ic_nav_trips"
            android:tint="@color/booking_muted" />

        <TextView
            android:id="@+id/text_manager_transactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Giao dịch"
            android:textColor="@color/booking_muted"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_manager_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/icon_manager_profile"
            android:layout_width="34dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_manager_icon_idle"
            android:contentDescription="Hồ sơ"
            android:padding="6dp"
            android:src="@drawable/ic_nav_profile"
            android:tint="@color/booking_muted" />

        <TextView
            android:id="@+id/text_manager_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Hồ sơ"
            android:textColor="@color/booking_muted"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

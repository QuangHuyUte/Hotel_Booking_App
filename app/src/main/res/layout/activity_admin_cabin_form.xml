<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_serein"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="760dp"
        android:orientation="vertical"
        android:padding="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_panel"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_form_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Create New Cabin"
                android:textColor="@color/primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Cabin Name"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_cabin_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Name"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Location"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_location"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Location"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Max Capacity"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_capacity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Max Capacity"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Regular Price"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_price"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Price"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Discount"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_discount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Discount"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Description"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_description"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Description"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Amenities"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/container_amenities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Cabin Image"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_pick_image"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_button_primary"
                android:text="Pick an Image"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_image"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Image URL or picked image URI"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <Button
                android:id="@+id/button_save_cabin"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_primary"
                android:text="Create Cabin"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_status"
                android:padding="10dp"
                android:textColor="@color/muted" />
        </LinearLayout>

        <Button
            android:id="@+id/button_back_bottom"
            android:layout_width="116dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>

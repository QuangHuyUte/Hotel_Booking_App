<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_auth_panel"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/image_cabin"
        android:layout_width="124dp"
        android:layout_height="112dp"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_cabin_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_cabin_capacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_cabin_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/primary"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_cabin_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="-> Tap to reserve"
            android:textColor="@color/muted"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>

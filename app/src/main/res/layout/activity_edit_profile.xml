<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_serein"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="760dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <Button
            android:id="@+id/button_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_back_circle"
            android:drawableTop="@drawable/ic_back_chevron"
            android:elevation="4dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text=""
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="34dp"
            android:paddingEnd="28dp"
            android:paddingBottom="34dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Cập nhật hồ sơ"
                android:textColor="@color/primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_name"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="38dp"
                android:background="@drawable/bg_input"
                android:hint="Họ và tên"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Email"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_phone"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Số điện thoại"
                android:inputType="phone"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_national_id"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="CCCD / CMND"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_birth"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Ngày sinh"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <EditText
                android:id="@+id/edit_address"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/button_save_profile"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_primary"
                android:text="Cập nhật hồ sơ"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_new_password"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input"
                android:hint="Mật khẩu mới"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:visibility="gone" />

            <Button
                android:id="@+id/button_change_password"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_primary"
                android:text="Đổi mật khẩu"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_status"
                android:padding="10dp"
                android:textColor="@color/muted"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/button_back_bottom"
            android:layout_width="116dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Quay lại"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
